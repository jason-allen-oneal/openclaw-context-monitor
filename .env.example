# Context-Drift (standalone)
# NOTE: If you publish this, do NOT commit a real token.

PORT=18790

# Gateway HTTP base (NOT ws://). Example:
#   http://127.0.0.1:18789
OPENCLAW_GATEWAY_HTTP_URL=http://127.0.0.1:18789

# Gateway token (treat like a password)
OPENCLAW_GATEWAY_TOKEN=

# Optional: allow cross-origin (default: disabled)
# CONTEXT_DRIFT_CORS_ORIGINS=http://localhost:5174,http://localhost:5176
CONTEXT_DRIFT_CORS_ORIGINS=
